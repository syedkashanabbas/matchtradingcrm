# =============================================================================
# MatchTrading CRM Backend Environment Variables
# =============================================================================

# Node Environment
NODE_ENV=development

# Server Configuration
PORT=5000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/matchtrading

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate secure secrets: openssl rand -base64 32
JWT_ACCESS_SECRET=your_jwt_access_secret_here_minimum_32_characters
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_minimum_32_characters

# =============================================================================
# STRIPE PAYMENT PROCESSING
# =============================================================================
# Get from Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Stripe Price IDs (get from Stripe Dashboard > Products > Pricing)
STRIPE_PRICE_ID=price_1your_price_id_here
STRIPE_FREE_PRICE_ID=price_1your_free_plan_price_id
STRIPE_PRO_PRICE_ID=price_1your_pro_plan_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_1your_enterprise_plan_price_id

# =============================================================================
# SECURITY & ENCRYPTION
# =============================================================================
# Generate secure key: openssl rand -base64 32
ENCRYPTION_KEY=your_encryption_key_here_minimum_32_characters

# =============================================================================
# CLIENT CONFIGURATION
# =============================================================================
# Frontend application URL
CLIENT_URL=http://localhost:3000

# =============================================================================
# OPTIONAL: EMAIL SERVICE (for future implementation)
# =============================================================================
# SendGrid Configuration (optional)
# SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
# FROM_EMAIL=noreply@yourdomain.com
# FROM_NAME=MatchTrading CRM

# SMTP Configuration (for password reset emails)
SMTP_HOST=exonoma.ai
SMTP_PORT=465
SMTP_USER=support@exonoma.ai
SMTP_PASS=SUPPORT@EXONOMA@0900+-$
EMAIL_FROM=support@exonoma.ai

# =============================================================================
# OPTIONAL: REDIS CONFIGURATION (for future caching)
# =============================================================================
# REDIS_URL=redis://localhost:6379

# =============================================================================
# OPTIONAL: LOGGING CONFIGURATION
# =============================================================================
# LOG_LEVEL=info
# LOG_FILE_PATH=./logs/app.log

# =============================================================================
# OPTIONAL: MONITORING & ANALYTICS
# =============================================================================
# SENTRY_DSN=https://your_sentry_dsn_here
# GOOGLE_ANALYTICS_ID=GA-XXXXXXXXXX

# =============================================================================
# OPTIONAL: FILE STORAGE (for future file uploads)
# =============================================================================
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-s3-bucket-name

# =============================================================================
# OPTIONAL: ADDITIONAL SECURITY
# =============================================================================
# API_KEY_SALT=your_api_key_salt_here_minimum_16_characters
# SESSION_SECRET=your_session_secret_here_minimum_32_characters
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

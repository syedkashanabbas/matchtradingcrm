generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  password           String
  firstName          String
  lastName           String
  role               Role             @default(CLIENT)
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  status             ClientStatus     @default(NEW)
  subscriptionEnd    DateTime?
  company            String?
  emailVerified      Boolean          @default(false)
  gracePeriodEnd     DateTime?
  phone              String?
  stripeCustomerId   String?
  onboardingProgress String           @default("not_started")
  referralCode       String?          @unique
  referredByCode     String?
  referredByUserId   String?
  registrationSource String?          @default("organic")
  country            String?
  termsAcceptedAt    DateTime?
  privacyAcceptedAt  DateTime?
  payoutReference    String? // IBAN / payment reference for commission payouts (M4)
  alerts             Alert[]
  commissionsEarned  Commission[]     @relation("CommissionAgent")
  commissionsCaused  Commission[]     @relation("CommissionSource")
  auditLogs          AuditEvent[]
  brokerAccounts     BrokerAccount[]
  networkEvents      NetworkEvent[]   @relation("NetworkEventUser")
  notifications      Notification[]
  onboardingSteps    OnboardingStep[]
  propAccounts       PropAccount[]
  subscriptions      Subscription[]
  referredBy         User?            @relation("UserReferrals", fields: [referredByUserId], references: [id])
  referrals          User[]           @relation("UserReferrals")
  qualificationSnapshots QualificationSnapshot[]
  travelPromoProgresses  TravelPromoProgress[]
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String
  provider             String             @default("stripe") // stripe | coingate
  externalOrderId      String? // CoinGate order id (crypto subscriptions)
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  plan                 String // plan code from the configurable catalog (M3)
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  gracePeriodEnd       DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeSubscriptionId])
  @@index([provider])
}

// CoinGate order reconciliation (M3, spec §6.2)
model CryptoOrder {
  id              String   @id @default(uuid())
  userId          String
  planCode        String
  coingateOrderId String?  @unique // id returned by CoinGate
  localOrderId    String   @unique // our order reference sent to CoinGate
  ipnToken        String // per-order secret echoed back in IPN callbacks
  amount          Decimal
  currency        String
  status          String   @default("new") // new | pending | confirming | paid | invalid | expired | canceled | refunded
  purpose         String   @default("subscription") // subscription | renewal
  paymentUrl      String?
  ipnHistory      Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model BrokerAccount {
  id                   String   @id @default(uuid())
  userId               String
  brokerName           String
  mt5AccountNumber     String
  mt5Password          String
  mt5Server            String
  brokerPortalPassword String?
  status               String   @default("review")
  archivedAt           DateTime?
  epAccountId          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PropAccount {
  id                 String    @id @default(uuid())
  userId             String
  firmName           String
  mt5AccountNumber   String
  mt5Password        String
  mt5Server          String
  phase              PropPhase @default(CHALLENGE)
  isActive           Boolean   @default(true)
  archivedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  status             String    @default("review")
  ftmoCreditDetail   String?
  ftmoAccountDetail  String?
  ftmoUserName       String?
  epAccountId        String?
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// EasierProp integration (M2)
// ============================================================

enum ProvisionStatus {
  PENDING
  KEY_CREATED
  PROP_ACCOUNT_CREATED
  BROKER_ACCOUNT_CREATED
  COMPLETED
  FAILED
  DECOMMISSIONED
}

model EasierPropProvision {
  id                String          @id @default(uuid())
  userId            String          @unique
  status            ProvisionStatus @default(PENDING)
  epApiKeyEncrypted String? // sk_ key encrypted with AES-256-GCM, stored right after POST /admin/keys
  epKeyId           String? // key UUID on the EasierProp side
  epPropAccountId   String?
  epBrokerAccountId String?
  failedStep        String?
  lastError         String?
  attemptCount      Int             @default(0)
  nextRetryAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([status])
  @@index([nextRetryAt])
}

model HedgeSetup {
  id                String   @id @default(uuid())
  userId            String
  propAccountId     String // CRM PropAccount FK
  brokerAccountId   String // CRM BrokerAccount FK
  epPropAccountId   String // EasierProp account id
  epBrokerAccountId String
  status            String   @default("active") // active | paused | archived
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// Queue for service-control and incremental-sync operations processed by the
// provisioning worker (never executed inline in HTTP requests).
model ServiceCommand {
  id           String    @id @default(uuid())
  userId       String
  type         String // START | STOP | DELETE | SYNC_PROP_ROTATION | SYNC_BROKER_REPLACE | SYNC_BROKER_ADD | SET_HEDGE_BROKER
  payload      Json?
  status       String    @default("PENDING") // PENDING | RUNNING | COMPLETED | FAILED
  attemptCount Int       @default(0)
  nextRetryAt  DateTime?
  lastError    String?
  createdBy    String? // admin id or "system"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, nextRetryAt])
  @@index([userId])
}

model Notification {
  id        String        @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean       @default(false)
  createdAt DateTime      @default(now())
  channels  String[]      @default(["in_app"])
  severity  AlertSeverity @default(MEDIUM)
  type      AlertType
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model AuditEvent {
  id        String        @id @default(uuid())
  userId    String?
  action    String
  resource  String
  details   Json?
  ipAddress String?       @db.Inet
  userAgent String?
  timestamp DateTime      @default(now())
  severity  AuditSeverity @default(MEDIUM)
  user      User?         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}

model OnboardingStep {
  id          String               @id @default(uuid())
  userId      String
  stepId      String
  status      OnboardingStepStatus @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stepId])
  @@index([userId])
}

model Alert {
  id        String        @id @default(uuid())
  userId    String
  type      AlertType
  title     String
  message   String
  severity  AlertSeverity @default(MEDIUM)
  isRead    Boolean       @default(false)
  channels  String[]      @default(["in_app"])
  metadata  Json?
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
}

model NetworkEvent {
  id            String   @id @default(uuid())
  userId        String
  eventType     String
  relatedUserId String?
  message       String
  createdAt     DateTime @default(now())
  user          User     @relation("NetworkEventUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

enum Role {
  ADMIN
  MANAGER
  CLIENT
}

enum ClientStatus {
  NEW
  ONBOARDING
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  TRIALING
}

enum OnboardingStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum AuditSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertType {
  PAYMENT_FAILURE
  ACCOUNT_CHANGE
  ADMIN_ACTION
  SUBSCRIPTION_EXPIRED
  PROVISIONING
  SERVICE_STATE
  COMMISSION
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================================
// Network marketing commissions (M4, spec §7.2)
// ============================================================

model CommissionPlan {
  id        String                @id @default(uuid())
  name      String
  isActive  Boolean               @default(false) // only one active plan
  createdAt DateTime              @default(now())
  levels    CommissionPlanLevel[]
}

model CommissionPlanLevel {
  id               String         @id @default(uuid())
  planId           String
  level            Int // 1 = direct referral
  rate             Decimal        @db.Decimal(5, 2) // percentage, e.g. 20.00
  // Qualification threshold (spec v1.1 §7.3): active paying directs the
  // beneficiary needs to receive commissions at this level (0 = always).
  minActiveDirects Int            @default(0)
  plan             CommissionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, level])
}

// Monthly frozen qualification state (spec v1.1 §7.4): computed at billing
// cycle start so a mid-month change never alters already-assigned commissions.
model QualificationSnapshot {
  id                String   @id @default(uuid())
  userId            String
  period            String // e.g. "2026-07"
  activeDirectCount Int
  qualifiesLevel2   Boolean
  qualifiesLevel3   Boolean
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([period])
}

// Time-boxed leaderboard competition (spec v1.1 §7.8)
model Challenge {
  id         String   @id @default(uuid())
  name       String
  metric     String // new_active_directs | revenue_generated | new_l2_unlocked
  prize      String
  startsAt   DateTime
  endsAt     DateTime
  status     String   @default("ACTIVE") // ACTIVE | FROZEN
  winnersLog Json? // leaderboard frozen at expiry
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status, endsAt])
}

// Threshold goal with a non-monetary prize (spec v1.1 §7.8)
model TravelPromo {
  id         String                @id @default(uuid())
  name       String
  metric     String // active_directs | revenue
  threshold  Decimal               @db.Decimal(12, 2)
  deadline   DateTime
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  progresses TravelPromoProgress[]

  @@index([deadline])
}

model TravelPromoProgress {
  id        String      @id @default(uuid())
  promoId   String
  userId    String
  status    String      @default("NOT_REACHED") // NOT_REACHED | REACHED | CONFIRMED | REDEEMED
  updatedAt DateTime    @updatedAt
  createdAt DateTime    @default(now())
  promo     TravelPromo @relation(fields: [promoId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoId, userId])
  @@index([userId])
}

model Commission {
  id                  String       @id @default(uuid())
  agentId             String // beneficiary (upline)
  sourceUserId        String // client who paid
  paymentRef          String // Stripe invoice id / CoinGate order id
  provider            String // stripe | coingate
  level               Int
  baseAmount          Decimal      @db.Decimal(12, 2) // payment amount
  rate                Decimal      @db.Decimal(5, 2)
  amount              Decimal      @db.Decimal(12, 2) // baseAmount * rate / 100
  currency            String
  // Dynamic compression (spec v1.1 §7.5): when the natural L2/L3 beneficiary
  // misses the qualification threshold, the row rolls up to the first
  // qualified sponsor above; the skipped node is kept for audit/disputes.
  wasCompressed         Boolean    @default(false)
  originalBeneficiaryId String?
  status              String       @default("EARNED") // EARNED | PAID | REVERSED
  // Refund arrived after the commission was already paid out: the amount is
  // carried over as a negative balance into the next payout period.
  reversedAfterPayout Boolean      @default(false)
  // Batch in which this reversed-after-payout amount was deducted (settled).
  carryOverBatchId    String?
  payoutBatchId       String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  agent               User         @relation("CommissionAgent", fields: [agentId], references: [id], onDelete: Cascade)
  sourceUser          User         @relation("CommissionSource", fields: [sourceUserId], references: [id], onDelete: Cascade)
  payoutBatch         PayoutBatch? @relation(fields: [payoutBatchId], references: [id])

  // Idempotency (spec v1.1 §7.7): at most one row per level per payment. With
  // compression the same agent can legitimately receive two rows from one
  // payment (a compressed L2 plus their own L3), so agentId is not unique.
  @@unique([paymentRef, level])
  @@index([agentId])
  @@index([agentId, status])
  @@index([paymentRef])
  @@index([createdAt])
}

model PayoutBatch {
  id          String       @id @default(uuid())
  periodStart DateTime
  periodEnd   DateTime
  totalAmount Decimal      @db.Decimal(12, 2)
  status      String       @default("OPEN") // OPEN | EXPORTED | PAID
  paidAt      DateTime?
  createdBy   String // admin id
  createdAt   DateTime     @default(now())
  commissions Commission[]

  @@index([status])
}

model PasswordResetOTP {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
  isUsed    Boolean  @default(false)

  @@unique([email])
  @@index([email])
  @@index([expiresAt])
}

enum PropPhase {
  CHALLENGE
  FUNDED
  ARCHIVED
}
